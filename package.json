{
  "name": "@fictionlab/db",
  "version": "1.0.0",
  "description": "FictionLab database layer and MCP writing servers",
  "type": "module",
  "exports": {
    ".": "./src/index.js",
    "./db": "./src/db.js",
    "./migrations": "./src/migrations.js",
    "./mcp-servers": "./src/mcps/index.js",
    "./http-server": "./src/http-sse-server.js"
  },
  "main": "src/index.js",
  "scripts": {
    "start": "node src/http-sse-server.js",
    "start:stdio": "node src/stdio-server.js",
    "start:orchestrator": "node server.js",
    "start:adapter": "node mcp-stdio-adapter.js",
    "dev": "node --watch src/http-sse-server.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RLRyals/MCP-Writing-Servers.git"
  },
  "keywords": ["fictionlab", "mcp", "writing", "database"],
  "author": "FictionLab",
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "restricted"
  },
  "bugs": {
    "url": "https://github.com/RLRyals/MCP-Writing-Servers/issues"
  },
  "homepage": "https://github.com/RLRyals/MCP-Writing-Servers#readme",
  "peerDependencies": {
    "pg": "^8"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "pg": "^8.16.3"
  }
}
